# Public Vite values from Neon Console > Connect > Auth / Data API
VITE_NEON_AUTH_URL=https://your-branch.neonauth.example/neondb/auth
VITE_NEON_DATA_API_URL=https://your-branch.apirest.example/neondb/rest/v1

# Direct (unpooled) Postgres URLs used only by Prisma CLI. Never prefix these
# with VITE_. Use a separate development branch and a disposable shadow branch.
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
SHADOW_DATABASE_URL=postgresql://user:password@shadow-host/database?sslmode=require
